{
  "name": "wc-stats-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "next dev",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "assert:schema-version": "node scripts/assert-schema-version.mjs",
    "build": "npm run lint && npm run typecheck && npm run assert:schema-version && next build && node scripts/copy-data.mjs",
    "generate:types": "node ../contract/scripts/generate-types.mjs src/lib/contract",
    "check:types": "node ../contract/scripts/generate-types.mjs src/lib/contract --check",
    "test": "vitest run"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next": "16.2.11",
    "radix-ui": "^1.6.5",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "shadcn": "^4.14.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "~4.3.3",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.11",
    "tailwindcss": "~4.3.3",
    "typescript": "~6.0.3",
    "vitest": "^3.2.7"
  }
}
